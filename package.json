{
  "name": "starling-ai",
  "displayName": "Starling Agent",
  "description": "Agent session manager — discover, pin, and organize AI coding sessions",
  "version": "0.1.4",
  "publisher": "huangsh",
  "icon": "icons/starling.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/huang-sh/Starling-ext"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Chat",
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:starling-spaces",
    "onView:starling-projects",
    "onView:starling-models",
    "onView:starling-sessions",
    "onCommand:starling.refresh",
    "onCommand:starling.resume",
    "onCommand:starling.pin",
    "onCommand:starling.pinToSpace",
    "onCommand:starling.removePin",
    "onCommand:starling.deleteSession",
    "onCommand:starling.showSession",
    "onCommand:starling.editSessionTitle",
    "onCommand:starling.forkSession",
    "onCommand:starling.sessionList",
    "onCommand:starling.sessionShow",
    "onCommand:starling.sessionIndexStatus",
    "onCommand:starling.sessionIndexRebuild",
    "onCommand:starling.sessionIndexClear",
    "onCommand:starling.loadMoreSessions",
    "onCommand:starling.loadMoreProjectSessions",
    "onCommand:starling.modelList",
    "onCommand:starling.modelAdd",
    "onCommand:starling.modelOpenSettings",
    "onCommand:starling.modelStart",
    "onCommand:starling.modelStartInCatalog",
    "onCommand:starling.modelDelete",
    "onCommand:starling.copySessionId",
    "onCommand:starling.catalogList",
    "onCommand:starling.catalogTree",
    "onCommand:starling.catalogShow",
    "onCommand:starling.catalogCreate",
    "onCommand:starling.catalogCreateChild",
    "onCommand:starling.catalogRemove",
    "onCommand:starling.catalogRename",
    "onCommand:starling.catalogDelete",
    "onCommand:starling.catalogDeleteWithSessions",
    "onCommand:starling.catalogTag",
    "onCommand:starling.catalogEdit",
    "onCommand:starling.catalogCopyName",
    "onCommand:starling.catalogCopyId",
    "onCommand:starling.catalogRunClaude",
    "onCommand:starling.catalogRunCodex",
    "onCommand:starling.projectList",
    "onCommand:starling.projectShow",
    "onCommand:starling.openProject",
    "onCommand:starling.copyProject"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "starling",
          "title": "Starling",
          "icon": "icons/starling_logo.svg"
        }
      ]
    },
    "views": {
      "starling": [
        {
          "id": "starling-spaces",
          "name": "Catalog",
          "icon": "$(layers)"
        },
        {
          "id": "starling-projects",
          "name": "Projects",
          "icon": "$(repo)"
        },
        {
          "id": "starling-models",
          "name": "Models",
          "icon": "$(sparkle)"
        },
        {
          "id": "starling-sessions",
          "name": "Monitor",
          "icon": "$(server)"
        }
      ]
    },
    "commands": [
      {
        "command": "starling.refresh",
        "category": "Starling",
        "title": "Refresh"
      },
      {
        "command": "starling.resume",
        "category": "Starling",
        "title": "Resume Session",
        "icon": "$(play)"
      },
      {
        "command": "starling.pin",
        "category": "Starling",
        "title": "Pin Session",
        "icon": "$(pin)"
      },
      {
        "command": "starling.pinToSpace",
        "category": "Starling",
        "title": "Pin to Catalog"
      },
      {
        "command": "starling.removePin",
        "category": "Starling",
        "title": "Remove Pin",
        "icon": "$(pinned-dirty)"
      },
      {
        "command": "starling.deleteSession",
        "category": "Starling",
        "title": "Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "starling.showSession",
        "category": "Starling",
        "title": "Show Session Details",
        "icon": "$(eye)"
      },
      {
        "command": "starling.editSessionTitle",
        "category": "Starling",
        "title": "Edit Session Title",
        "icon": "$(edit)"
      },
      {
        "command": "starling.forkSession",
        "category": "Starling",
        "title": "Fork Session",
        "icon": "$(repo-forked)"
      },
      {
        "command": "starling.sessionList",
        "category": "Starling",
        "title": "List Sessions"
      },
      {
        "command": "starling.sessionShow",
        "category": "Starling",
        "title": "Show Session"
      },
      {
        "command": "starling.sessionIndexStatus",
        "category": "Starling",
        "title": "Session Index Status"
      },
      {
        "command": "starling.sessionIndexRebuild",
        "category": "Starling",
        "title": "Rebuild Session Index"
      },
      {
        "command": "starling.sessionIndexClear",
        "category": "Starling",
        "title": "Clear Session Index"
      },
      {
        "command": "starling.loadMoreSessions",
        "category": "Starling",
        "title": "Load More Sessions"
      },
      {
        "command": "starling.loadMoreProjectSessions",
        "category": "Starling",
        "title": "Load More Project Sessions"
      },
      {
        "command": "starling.modelList",
        "category": "Starling",
        "title": "List Models"
      },
      {
        "command": "starling.modelAdd",
        "category": "Starling",
        "title": "Add Model",
        "icon": "$(add)"
      },
      {
        "command": "starling.modelOpenSettings",
        "category": "Starling",
        "title": "Open Model Settings",
        "icon": "$(go-to-file)"
      },
      {
        "command": "starling.modelStart",
        "category": "Starling",
        "title": "Start Agent",
        "icon": "$(play)"
      },
      {
        "command": "starling.modelStartInCatalog",
        "category": "Starling",
        "title": "Start Agent in Catalog",
        "icon": "$(play)"
      },
      {
        "command": "starling.modelDelete",
        "category": "Starling",
        "title": "Delete Model Profile",
        "icon": "$(trash)"
      },
      {
        "command": "starling.catalogList",
        "category": "Starling",
        "title": "List Catalogs"
      },
      {
        "command": "starling.catalogTree",
        "category": "Starling",
        "title": "Catalog Tree"
      },
      {
        "command": "starling.catalogShow",
        "category": "Starling",
        "title": "Show Catalog"
      },
      {
        "command": "starling.catalogCreate",
        "category": "Starling",
        "title": "Create Catalog",
        "icon": "$(add)"
      },
      {
        "command": "starling.catalogCreateChild",
        "category": "Starling",
        "title": "Create Child Catalog",
        "icon": "$(add)"
      },
      {
        "command": "starling.catalogRemove",
        "category": "Starling",
        "title": "Remove Catalog"
      },
      {
        "command": "starling.catalogRename",
        "category": "Starling",
        "title": "Rename Catalog",
        "icon": "$(edit)"
      },
      {
        "command": "starling.catalogDelete",
        "category": "Starling",
        "title": "Delete Catalog",
        "icon": "$(trash)"
      },
      {
        "command": "starling.catalogDeleteWithSessions",
        "category": "Starling",
        "title": "Delete Catalog with Sessions",
        "icon": "$(trash)"
      },
      {
        "command": "starling.catalogTag",
        "category": "Starling",
        "title": "Tag Catalog"
      },
      {
        "command": "starling.catalogEdit",
        "category": "Starling",
        "title": "Edit Catalog"
      },
      {
        "command": "starling.catalogCopyName",
        "category": "Starling",
        "title": "Copy Catalog Name",
        "icon": "$(copy)"
      },
      {
        "command": "starling.catalogCopyId",
        "category": "Starling",
        "title": "Copy Catalog ID",
        "icon": "$(copy)"
      },
      {
        "command": "starling.catalogRunClaude",
        "category": "Starling",
        "title": "Claude",
        "icon": "$(sparkle)"
      },
      {
        "command": "starling.catalogRunCodex",
        "category": "Starling",
        "title": "Codex",
        "icon": "$(terminal)"
      },
      {
        "command": "starling.projectList",
        "category": "Starling",
        "title": "List Projects"
      },
      {
        "command": "starling.projectShow",
        "category": "Starling",
        "title": "Show Project"
      },
      {
        "command": "starling.openProject",
        "category": "Starling",
        "title": "Open Project in New Window",
        "icon": "$(window)"
      },
      {
        "command": "starling.copyProject",
        "category": "Starling",
        "title": "Copy Project Path",
        "icon": "$(copy)"
      },
      {
        "command": "starling.copySessionId",
        "category": "Starling",
        "title": "Copy Session ID",
        "icon": "$(copy)"
      }
    ],
    "submenus": [
      {
        "id": "starling.runAgentMenu",
        "label": "Run Agent",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "starling.resume",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == project-session",
          "group": "sessionContext@1"
        },
        {
          "command": "starling.showSession",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == project-session",
          "group": "sessionContext@2"
        },
        {
          "command": "starling.editSessionTitle",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == project-session",
          "group": "sessionContext@3"
        },
        {
          "command": "starling.openProject",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == project-session",
          "group": "sessionContext@4"
        },
        {
          "command": "starling.copyProject",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == project-session",
          "group": "sessionContext@5"
        },
        {
          "command": "starling.copySessionId",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == project-session",
          "group": "sessionContext@6"
        },
        {
          "command": "starling.pin",
          "when": "viewItem == session-unpinned || viewItem == project-session",
          "group": "sessionContext@7"
        },
        {
          "command": "starling.pinToSpace",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == project-session",
          "group": "sessionContext@8"
        },
        {
          "command": "starling.removePin",
          "when": "viewItem == session-pinned",
          "group": "sessionContext@9"
        },
        {
          "command": "starling.deleteSession",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == project-session",
          "group": "sessionContext@10"
        },
        {
          "command": "starling.modelStart",
          "when": "viewItem == model-profile || viewItem == model-current",
          "group": "modelContext@1"
        },
        {
          "command": "starling.modelStartInCatalog",
          "when": "viewItem == model-profile || viewItem == model-current",
          "group": "modelContext@2"
        },
        {
          "command": "starling.modelOpenSettings",
          "when": "viewItem == model-profile || viewItem == model-current",
          "group": "modelContext@3"
        },
        {
          "command": "starling.modelDelete",
          "when": "viewItem == model-profile",
          "group": "modelContext@9"
        },
        {
          "command": "starling.openProject",
          "when": "viewItem == project || viewItem == project-folder",
          "group": "projectContext@1"
        },
        {
          "command": "starling.copyProject",
          "when": "viewItem == project || viewItem == project-folder",
          "group": "projectContext@2"
        },
        {
          "submenu": "starling.runAgentMenu",
          "when": "viewItem == catalog",
          "group": "catalogContext@0"
        },
        {
          "command": "starling.catalogCreateChild",
          "when": "viewItem == catalog",
          "group": "catalogContext@1"
        },
        {
          "command": "starling.catalogRename",
          "when": "viewItem == catalog",
          "group": "catalogContext@2"
        },
        {
          "command": "starling.catalogDelete",
          "when": "viewItem == catalog",
          "group": "catalogContext@3"
        },
        {
          "command": "starling.catalogDeleteWithSessions",
          "when": "viewItem == catalog",
          "group": "catalogContext@4"
        },
        {
          "command": "starling.catalogEdit",
          "when": "viewItem == catalog",
          "group": "catalogContext@5"
        },
        {
          "command": "starling.catalogCopyName",
          "when": "viewItem == catalog",
          "group": "catalogContext@6"
        },
        {
          "command": "starling.catalogCopyId",
          "when": "viewItem == catalog",
          "group": "catalogContext@7"
        },
        {
          "command": "starling.resume",
          "when": "viewItem == session-pin",
          "group": "catalogSession@1"
        },
        {
          "command": "starling.showSession",
          "when": "viewItem == session-pin",
          "group": "catalogSession@2"
        },
        {
          "command": "starling.editSessionTitle",
          "when": "viewItem == session-pin",
          "group": "catalogSession@3"
        },
        {
          "command": "starling.forkSession",
          "when": "viewItem == session-pin",
          "group": "catalogSession@4"
        },
        {
          "command": "starling.openProject",
          "when": "viewItem == session-pin",
          "group": "catalogSession@5"
        },
        {
          "command": "starling.copyProject",
          "when": "viewItem == session-pin",
          "group": "catalogSession@6"
        },
        {
          "command": "starling.copySessionId",
          "when": "viewItem == session-pin",
          "group": "catalogSession@7"
        },
        {
          "command": "starling.removePin",
          "when": "viewItem == session-pin",
          "group": "catalogSession@8"
        },
        {
          "command": "starling.deleteSession",
          "when": "viewItem == session-pin",
          "group": "catalogSession@9"
        }
      ],
      "view/title": [
        {
          "command": "starling.catalogCreate",
          "when": "view == starling-spaces",
          "group": "navigation@1"
        },
        {
          "command": "starling.modelAdd",
          "when": "view == starling-models",
          "group": "navigation@1"
        },
        {
          "command": "starling.refresh",
          "when": "view == starling-sessions || view == starling-spaces || view == starling-projects || view == starling-models",
          "group": "navigation@9"
        }
      ],
      "starling.runAgentMenu": [
        {
          "command": "starling.catalogRunClaude",
          "group": "navigation@1"
        },
        {
          "command": "starling.catalogRunCodex",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "starling.catalogRunClaude",
          "when": "false"
        },
        {
          "command": "starling.catalogRunCodex",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Starling",
      "properties": {
        "starling.cliPath": {
          "type": "string",
          "default": "starling",
          "description": "Path to the Starling CLI executable. Use an absolute path if the VS Code extension host cannot find starling on PATH."
        },
        "starling.homePath": {
          "type": "string",
          "default": "",
          "description": "Optional Starling data directory. Leave empty to use ~/.starling. When set, the extension passes this path as STARLING_HOME to the Starling CLI."
        },
        "starling.cacheTtlSeconds": {
          "type": "number",
          "default": 30,
          "description": "How long CLI query results are cached in seconds. Set to 0 to disable cache.",
          "minimum": 0
        },
        "starling.monitorRefreshSeconds": {
          "type": "number",
          "default": 5,
          "description": "How often the extension refreshes live session status in the background. Set to 0 to use the default.",
          "minimum": 0
        },
        "starling.monitorCacheTtlSeconds": {
          "type": "number",
          "default": 2,
          "description": "How long live monitor snapshots are cached in seconds. The extension keeps the last good snapshot if a refresh fails.",
          "minimum": 0
        },
        "starling.projectSessionLimit": {
          "type": "number",
          "default": 30,
          "description": "Number of sessions shown per project node before requiring Load more. Set to 0 for all.",
          "minimum": 0
        },
        "starling.sessionTreeLimit": {
          "type": "number",
          "default": 50,
          "description": "Number of sessions loaded per batch in the Sessions view. Set to 0 to load all sessions.",
          "minimum": 0
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test test/*.test.cjs"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "extensionKind": [
    "workspace"
  ]
}
